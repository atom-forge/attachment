{
	"name": "@atom-forge/attachment",
	"version": "0.3.1",
	"description": "Attachment management for your ORM",
	"homepage": "https://github.com/atom-forge/attachment#readme",
	"repository": {
		"url": "git://github.com/atom-forge/attachment.git"
	},
	"bugs": {
		"url": "https://github.com/atom-forge/attachment/issues"
	},
	"keywords": [
		"attachment",
		"file-upload",
		"prisma",
		"typescript",
		"s3",
		"image"
	],
	"author": {
		"name": "Gergely Laborci",
		"url": "https://github.com/laborci"
	},
	"license": "SEE LICENSE IN LICENSE",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./client": {
			"import": "./dist/client.js",
			"types": "./dist/client.d.ts"
		}
	},
	"files": [
		"dist",
		"docs",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"build": "rm -rf dist && tsc",
		"prepublishOnly": "bun run scripts/prepublish.ts && bun run build",
		"release": "npm publish --access public"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1046.0",
		"mime": "^4.0.0"
	},
	"peerDependencies": {
		"music-metadata": ">=11.12.0",
		"sharp": ">=0.32.0",
		"zod": ">=4.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.2",
		"music-metadata": "^11.12.3",
		"sharp": "^0.34.5",
		"typescript": "^6.0.2",
		"zod": "^4.3.6"
	}
}
